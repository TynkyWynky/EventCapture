{
  "name": "eventcapture",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "start:dev-client": "expo start --dev-client",
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1 -CheckOnly",
    "start:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1",
    "start:services": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1",
    "dev:launch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1",
    "dev:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1 -CheckOnly",
    "backend:start": ".\\backend\\.venv\\Scripts\\python -m uvicorn backend.app:app --host 0.0.0.0 --port 8000",
    "backend:migrate": ".\\backend\\.venv\\Scripts\\python -m alembic upgrade head",
    "backend:migration:current": ".\\backend\\.venv\\Scripts\\python -m alembic current",
    "backend:verify-schema": ".\\backend\\.venv\\Scripts\\python -m backend.verify_schema",
    "backend:seed": ".\\backend\\.venv\\Scripts\\python backend\\seed.py",
    "backend:test": ".\\backend\\.venv\\Scripts\\python -m unittest discover -s backend\\tests -p \"test_*.py\"",
    "check:env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/launch-dev.ps1 -CheckOnly",
    "events:brussels:preview": "python ./scripts/import_brussels_events.py --dry-run",
    "events:brussels:import": "python ./scripts/import_brussels_events.py",
    "events:brussels:sync": "python ./scripts/import_brussels_events.py --all-pages --page-size 250 --limit 0 --seed-output ./constants/generatedBrusselsEvents.ts --prune-existing",
    "events:brussels:sync:all": "python ./scripts/import_brussels_events.py --all-pages --page-size 250 --include-all-categories --limit 0 --seed-output ./constants/generatedBrusselsEvents.ts --prune-existing",
    "reset-project": "node ./scripts/reset-project.js",
    "build:android": "npm run build:apk",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:aab": "npx eas-cli build --platform android --profile production",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^14.0.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
