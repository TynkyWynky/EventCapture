EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8000
EVENTCAPTURE_ANDROID_ALLOW_CLEARTEXT=true

# Production example:
# EXPO_PUBLIC_APP_ENV=production
# EXPO_PUBLIC_BACKEND_API_URL=https://api.eventcapture.app
# EVENTCAPTURE_ANDROID_ALLOW_CLEARTEXT=false

EVENTCAPTURE_ENVIRONMENT=development
EVENTCAPTURE_HOST=0.0.0.0
EVENTCAPTURE_PORT=8000
EVENTCAPTURE_DATABASE_URL=sqlite+pysqlite:///backend/eventcapture.db
EVENTCAPTURE_DATABASE_ECHO=false
EVENTCAPTURE_SCHEMA_MANAGEMENT_MODE=auto

EVENTCAPTURE_AUTH_JWT_SECRET=replace-me
EVENTCAPTURE_AUTH_ACCESS_TOKEN_MINUTES=1440
EVENTCAPTURE_REQUIRE_INFERENCE_AUTH=false
EVENTCAPTURE_RATE_LIMIT_LOGIN_ATTEMPTS=50
EVENTCAPTURE_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
EVENTCAPTURE_RATE_LIMIT_REGISTER_ATTEMPTS=100
EVENTCAPTURE_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
EVENTCAPTURE_RATE_LIMIT_PASSWORD_RESET_ATTEMPTS=20
EVENTCAPTURE_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=900
EVENTCAPTURE_RATE_LIMIT_SUPPORT_ATTEMPTS=50
EVENTCAPTURE_RATE_LIMIT_SUPPORT_WINDOW_SECONDS=900
EVENTCAPTURE_RATE_LIMIT_SEARCH_ATTEMPTS=200
EVENTCAPTURE_RATE_LIMIT_SEARCH_WINDOW_SECONDS=60
EVENTCAPTURE_RATE_LIMIT_EVENT_SOCIAL_ATTEMPTS=100
EVENTCAPTURE_RATE_LIMIT_EVENT_SOCIAL_WINDOW_SECONDS=60

EVENTCAPTURE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8081
EVENTCAPTURE_CORS_ALLOW_ORIGIN_REGEX=

EVENTCAPTURE_MEDIA_BACKEND=local
EVENTCAPTURE_MEDIA_ROOT=backend/storage/media
EVENTCAPTURE_DEBUG_DIR=backend/debug

EVENTCAPTURE_INFERENCE_WORKERS=2
EVENTCAPTURE_MAX_CONCURRENT_INFERENCE=2
EVENTCAPTURE_MAX_UPLOAD_BYTES=10485760

EVENTCAPTURE_BOOTSTRAP_USERS_ENABLED=true
EVENTCAPTURE_BOOTSTRAP_ADMIN_EMAIL=admin
EVENTCAPTURE_BOOTSTRAP_ADMIN_PASSWORD=admin
EVENTCAPTURE_BOOTSTRAP_DEMO_EMAIL=demo@eventcapture.app
EVENTCAPTURE_BOOTSTRAP_DEMO_PASSWORD=eventcapture123
EVENTCAPTURE_SMTP_HOST=
EVENTCAPTURE_SMTP_PORT=587
EVENTCAPTURE_SMTP_USERNAME=
EVENTCAPTURE_SMTP_PASSWORD=
EVENTCAPTURE_SMTP_USE_TLS=true
EVENTCAPTURE_SMTP_USE_SSL=false
EVENTCAPTURE_SMTP_FROM_EMAIL=
EVENTCAPTURE_SUPPORT_NOTIFICATION_EMAILS=support@example.com
EVENTCAPTURE_SUPPORT_CONFIRMATION_ENABLED=false
