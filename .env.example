EXPO_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8000

EVENTCAPTURE_ENV=development
EVENTCAPTURE_DEBUG=true
EVENTCAPTURE_HOST=0.0.0.0
EVENTCAPTURE_PORT=8000
EVENTCAPTURE_DATABASE_PATH=backend/eventcapture.db
EVENTCAPTURE_SECRET_KEY=change-me-for-production
